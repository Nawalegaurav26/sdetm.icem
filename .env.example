# ICEM 2026 - Environment Configuration (Hybrid Setup)

# 1. FRONTEND CONFIG (@ /src)
# -----------------------------
# Base URL for your standalone Railway Backend (e.g., https://my-server.railway.app)
VITE_API_URL=http://localhost:5000

# Supabase Credentials (Used ONLY for PDF File Storage)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key


# 2. BACKEND CONFIG (@ /server)
# ------------------------------
# Your Railway PostgreSQL Database URL
DATABASE_URL=postgresql://user:pass@host:port/dbname?sslmode=require

# Email Configuration (For Customized OTPs)
# Note: Use a Gmail "App Password" (16 digits) for EMAIL_PASS
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
PORT=5000
